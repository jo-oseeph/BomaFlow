# Supabase — required for fetching listings from the database
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=you-anon-key

# Note: Supabase docs also refer to this as the "publishable" key.
# Either VITE_SUPABASE_ANON_KEY or VITE_SUPABASE_PUBLISHABLE_KEY works;
# this project reads VITE_SUPABASE_ANON_KEY.
